datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Policy {
  id           Int      @id @default(autoincrement())
  policyNumber String   @unique
  holderName   String
  insurerName  String
  type         String
  status       String
  premium      Float
  startDate    DateTime
  endDate      DateTime
  agentId      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id])
}

model Agent {
  id       String   @id
  name     String
  email    String
  policies Policy[]
}
